{% if changeSet is not empty %}
{% set title = title | default('Gewijzigde velden') %}

<details>
    <summary class="explanation">{{ title }}</summary>
    <div class="table">
        <table>
            <thead>
                <tr>
                    <th>Veld</th>
                    {% if isNew|default(false) == false %}
                        <th>Oude waarde</th>
                    {% endif %}
                    <th>Nieuwe waarde</th>
                </tr>
            </thead>
            <tbody>
                {% for field, values in changeSet %}
                    <tr>
                        <td class="logboek-update-field">{{ field | transform_dossier_label }}</td>
                        {% if isNew|default(false) == false %}
                            <td class="logboek-update-original-value">
                                {% if values[0] is same as(false) %}
                                    Nee
                                {% elseif values[0] is same as(true) %}
                                    Ja
                                {% elseif values[0] is null %}
                                    Geen waarde
                                {% elseif values[0]['naam'] is defined %}
                                    <span title={{ values[0]['naam'] }}>{{ values[0]['naam'] }}</span>
                                {% elseif values[0] is iterable %}
                                    Kan waarde niet tonen
                                {% else %}
                                    <span title={{ values[0] }}>{{ values[0] }}</span>
                                {% endif %}
                            </td>
                        {% endif %}
                        <td class="logboek-update-updated-value">
                            {% if values[1] is same as(false) %}
                                Nee
                            {% elseif values[1] is same as(true) %}
                                Ja
                            {% elseif values[1] is null %}
                                Geen waarde
                            {% elseif values[1]['naam'] is defined %}
                                <span title={{ values[1]['naam'] }}>{{ values[1]['naam'] }}</span
                            {% elseif values[1] is iterable %}
                                Kan waarde niet tonen
                            {% else %}
                                <span title={{ values[1] }}>{{ values[1] }}</span>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</details>
{% else %}
    <p class="logboek-no-updates">Er zijn geen velden bijgewerkt</p>
{% endif %}
