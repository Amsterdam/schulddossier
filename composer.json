{
  "type": "project",
  "license": "MPLv2",
  "require": {
    "php": "^8.4",
    "ext-iconv": "*",
    "ext-zip": "*",
    "doctrine/doctrine-bundle": "^2.1",
    "doctrine/doctrine-migrations-bundle": "^3.0",
    "doctrine/orm": "^2.9",
    "ezyang/htmlpurifier": "^4.19",
    "guzzlehttp/guzzle": "^7.7.0",
    "jshjohnson/choices": "3.0.3",
    "knplabs/knp-paginator-bundle": "^6.0.0",
    "lcobucci/jwt": "^4.0",
    "league/flysystem": "^3.0",
    "mozilla/pdf.js": "1.9.426",
    "mrrio/jspdf": "1.3.5",
    "nelmio/security-bundle": "^3.4",
    "php-http/client-common": "^2.3",
    "php-http/discovery": "^1.3",
    "php-http/guzzle7-adapter": "*",
    "php-http/httplug": "^2.3",
    "php-http/httplug-bundle": "^2.0.0",
    "php-http/message": "^1.6",
    "php-soap/ext-soap-engine": "^1.7",
    "php-soap/xml": "^1.8",
    "phpoffice/phpspreadsheet": "1.29.*",
    "phpoffice/phpword": "^1.4",
    "phpro/soap-client": "^4.0",
    "phpseclib/phpseclib": "^2.0",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0.0",
    "psr/http-message": "^1.0",
    "rollerworks/password-strength-validator": "^2.0",
    "symfony/asset": "*",
    "symfony/cache": "*",
    "symfony/console": "*",
    "symfony/dependency-injection": "*",
    "symfony/expression-language": "*",
    "symfony/filesystem": "*",
    "symfony/flex": "^1.0",
    "symfony/form": "*",
    "symfony/framework-bundle": "*",
    "symfony/http-client": "*",
    "symfony/http-foundation": "*",
    "symfony/mailer": "*",
    "symfony/maker-bundle": "^1.1",
    "symfony/monolog-bundle": "^3.1",
    "symfony/proxy-manager-bridge": "*",
    "symfony/security-bundle": "*",
    "symfony/serializer": "*",
    "symfony/templating": "*",
    "symfony/translation": "*",
    "symfony/twig-bundle": "*",
    "symfony/validator": "*",
    "symfony/webpack-encore-bundle": "^2.0",
    "symfony/workflow": "*",
    "symfony/yaml": "*",
    "twig/twig": "^3.0"
  },
  "require-dev": {
    "doctrine/doctrine-fixtures-bundle": "^4.0.0",
    "laminas/laminas-code": "^4.8.0",
    "rector/rector": "^2.0",
    "symfony/debug-bundle": "*",
    "symfony/dotenv": "*",
    "symfony/stopwatch": "*",
    "symfony/var-dumper": "*",
    "symfony/web-profiler-bundle": "*",
    "squizlabs/php_codesniffer": "*"
  },
  "config": {
      "platform": {
          "php": "8.4",
          "ext-gd": "1"
      },
      "preferred-install": {
          "*": "dist"
      },
      "sort-packages": true,
      "allow-plugins": {
          "composer/package-versions-deprecated": true,
          "robloach/component-installer": true,
          "symfony/flex": true,
          "composer/installers": true,
          "oomphinc/composer-installers-extender": true,
          "php-http/discovery": true
      }
  },
    "autoload": {
        "psr-4": {
            "GemeenteAmsterdam\\FixxxSchuldhulp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GemeenteAmsterdam\\FixxxSchuldhulp\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php71": "*",
        "symfony/polyfill-php70": "*",
        "symfony/polyfill-php56": "*"
    },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install --symlink --relative %PUBLIC_DIR%": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ]
  },
  "conflict": {
      "symfony/symfony": "*"
  },
  "extra": {
      "symfony": {
          "id": "01C78G17XCNVEZ49WHBEVGCP02",
          "allow-contrib": false,
          "require": "7.2.*"
      }
  },
  "repositories": [
      {
          "type": "vcs",
          "url": "git@github.com:conductionnl/filesystemoperations.git"
      },
      {
          "type": "package",
          "package": {
              "name": "mozilla/pdf.js",
              "version": "1.9.426",
              "dist": {
                  "url": "https://github.com/mozilla/pdf.js/releases/download/v1.9.426/pdfjs-1.9.426-dist.zip",
                  "type": "zip"
              }
          }
      },
      {
          "type": "package",
          "package": {
              "name": "mrrio/jspdf",
              "version": "1.3.5",
              "dist": {
                  "url": "https://github.com/MrRio/jsPDF/archive/v1.3.5.zip",
                  "type": "zip"
              }
          }
      },
      {
          "type": "package",
          "package": {
              "name": "jshjohnson/choices",
              "version": "3.0.3",
              "dist": {
                  "url": "https://github.com/jshjohnson/Choices/archive/v3.0.3.zip",
                  "type": "zip"
              }
          }
      }
  ]
}

  